# ════════════════════════════════════════════════════════════════
# MedVisionSort — Backend Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env or serviceAccountKey.json to Git.
# ════════════════════════════════════════════════════════════════

# ── Flask server ─────────────────────────────────────────────────
# Set FLASK_DEBUG=true ONLY on a developer machine, never in production.
FLASK_DEBUG=false

# Bind to 127.0.0.1 (loopback) for local development.
# Set to 0.0.0.0 only if you need LAN access AND have other network controls.
FLASK_HOST=127.0.0.1
FLASK_PORT=5001

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of exact origins the browser is allowed to call from.
ALLOWED_ORIGINS=http://localhost:4200

# ── File upload ──────────────────────────────────────────────────
# Maximum upload size in bytes (default: 16 MB = 16777216).
MAX_CONTENT_LENGTH=16777216

# ── Authentication — Mode 1: Firebase Admin SDK (recommended) ────
# Download from Firebase Console → Project Settings → Service Accounts
#                                → Generate new private key
# Save the downloaded JSON file and set the path below.
# This file must be listed in .gitignore (it already is).
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# ── Authentication — Mode 2: API Key fallback ────────────────────
# Used ONLY when serviceAccountKey.json is not present.
# Generate a strong key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# The Angular frontend must send this value as:
#   Authorization: Bearer <API_SECRET_KEY>
API_SECRET_KEY=
