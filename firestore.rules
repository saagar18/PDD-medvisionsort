// firestore.rules — Firestore Security Rules (v5 FIX)
// ─────────────────────────────────────────────────────────
// DEPLOY with: firebase deploy --only firestore:rules
//
// Rules:
//   1. Only authenticated Firebase users can READ documents.
//   2. WRITE to medical_images is allowed for authenticated users
//      (the Angular frontend saves scan results after classification).
//   3. No unauthenticated access to any collection.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── medical_images: core patient scan records ────────────────────────────
    match /medical_images/{imageId} {
      // Read: any authenticated user can view scan records
      allow read: if request.auth != null;

      // Write: authenticated users may create/update scan records.
      // The Angular frontend writes after successful AI classification.
      // Fields are validated so only expected keys are accepted.
      allow write: if request.auth != null
        && request.resource.data.keys().hasAll(['id', 'type', 'confidence', 'patientId', 'patientName', 'date', 'status'])
        && request.resource.data.confidence is number
        && request.resource.data.confidence >= 0
        && request.resource.data.confidence <= 1;

      // Hard delete: not allowed from client — use Admin SDK for deletions
      allow delete: if false;
    }

    // ── Deny all other collections by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
